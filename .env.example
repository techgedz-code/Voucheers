# ---- App ----
# Public base URL of the app (used to build QR/scan/wallet links). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Supabase ----
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe for the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SERVER ONLY — never expose to the browser). Used by Super Admin / system jobs.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Email (Resend) ----
RESEND_API_KEY=
# Verified "from" address, e.g. "Voucher App <vouchers@yourdomain.com>"
EMAIL_FROM=Voucher App <onboarding@resend.dev>

# ---- Google Places (optional in dev; used for outlet Place ID lookup) ----
GOOGLE_MAPS_API_KEY=

# ---- IP geolocation (optional; ipinfo token for abuse clustering) ----
IPINFO_TOKEN=
